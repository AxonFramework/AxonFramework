<Configuration>
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>
        <List name="TestAppender" />
    </Appenders>
    <Loggers>
        <Root level="info">
            <AppenderRef ref="TestAppender"/>
            <!-- Enable this if you want console messages while running the test using this configuration locally.
                 Leave disabled for CI to reduce log spam. -->
            <!-- <AppenderRef ref="Console"/> -->
        </Root>
    </Loggers>
</Configuration>
